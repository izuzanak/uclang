
class Main
{
  static public main(argv)
  {/*{{{*/

    // - construction -
    a = new Array();
    if (a.length() != 0)
    {
      new Exception("new Array() length: expected 0").throw();
    }

    a = [1,2,3];
    if (a.length() != 3)
    {
      new Exception("[1,2,3].length(): expected 3").throw();
    }

    // - mixed-type literal -
    a = [1,"two",3.0];
    if (a.length() != 3)
    {
      new Exception("mixed array length").throw();
    }
    if (a[0] != 1 or a[1] != "two" or a[2] != 3.0)
    {
      new Exception("mixed array contents").throw();
    }

    // - index access -
    a = [10,20,30];
    if (a[0] != 10) { new Exception("a[0]").throw(); }
    if (a[1] != 20) { new Exception("a[1]").throw(); }
    if (a[2] != 30) { new Exception("a[2]").throw(); }

    // - slice [a:b:] inclusive both ends -
    a = [0,1,2,3,4,5];
    sl = a[1:3:];
    if (sl != [1,2,3])
    {
      new Exception("[0..5][1:3:]: expected [1,2,3], got %s" % $sl).throw();
    }

    // - push -
    a = [1,2,3];
    a.push(4);
    a.push(5);
    if (a != [1,2,3,4,5])
    {
      new Exception("push 4,5: expected [1..5], got %s" % $a).throw();
    }

    // - pop -
    a = [1,2,3,4,5];
    if (a.pop() != 5) { new Exception("pop 5").throw(); }
    if (a.pop() != 4) { new Exception("pop 4").throw(); }
    if (a != [1,2,3])
    {
      new Exception("after 2 pops: expected [1,2,3], got %s" % $a).throw();
    }

    // - last() returns last element -
    a = [10,20,30];
    if (a.last() != 30)
    {
      new Exception("last(): expected 30").throw();
    }

    // - last() as lvalue -
    a = [10,20,30];
    a.last() = 99;
    if (a != [10,20,99])
    {
      new Exception("last() = 99: expected [10,20,99], got %s" % $a).throw();
    }

    // - clear -
    a = [1,2,3,4,5];
    a.clear();
    if (a.length() != 0)
    {
      new Exception("clear length").throw();
    }
    if (a != [])
    {
      new Exception("clear value").throw();
    }

    // - resize larger -
    a = [1,2,3];
    a.resize(5);
    if (a.length() != 5)
    {
      new Exception("resize(5): expected length 5").throw();
    }

    // - fill -
    a = [1,2,3,4,5];
    a.fill(7);
    if (a != [7,7,7,7,7])
    {
      new Exception("fill(7): got %s" % $a).throw();
    }

    // - concat + -
    a = [1,2,3] + [4,5,6];
    if (a != [1,2,3,4,5,6])
    {
      new Exception("[1,2,3]+[4,5,6]").throw();
    }

    // - += -
    a = [1,2,3];
    a += [4,5,6];
    if (a != [1,2,3,4,5,6])
    {
      new Exception("a += [4,5,6]").throw();
    }

    // - contain -
    a = [1,2,3,4,5];
    if (a.contain(3) != 1)
    {
      new Exception("contain(3): expected 1").throw();
    }
    if (a.contain(99) != 0)
    {
      new Exception("contain(99): expected 0").throw();
    }

    // - get_idx -
    if ([1,5,5,2,5].get_idx(5) != 1)
    {
      new Exception("get_idx(5): expected 1").throw();
    }

    // - get_idxs -
    idxs = [1,5,5,2,5].get_idxs(5);
    if (idxs.length() != 3)
    {
      new Exception("get_idxs(5) length: expected 3, got %s" % $idxs.length()).throw();
    }

    // - forward iteration via first_idx/next_idx -
    a = [10,20,30,40];
    collected = [];
    idx = a.first_idx();
    while (Blank != idx)
    {
      collected.push(a.item(idx));
      idx = a.next_idx(idx);
    }
    if (collected != [10,20,30,40])
    {
      new Exception("forward iter: got %s" % $collected).throw();
    }

    // - backward iteration via last_idx/prev_idx -
    collected = [];
    idx = a.last_idx();
    while (Blank != idx)
    {
      collected.push(a.item(idx));
      idx = a.prev_idx(idx);
    }
    if (collected != [40,30,20,10])
    {
      new Exception("backward iter: got %s" % $collected).throw();
    }

    // - for-each -
    sum = 0;
    for (x <- [1,2,3,4,5])
    {
      sum += x;
    }
    if (sum != 15)
    {
      new Exception("for-each sum: expected 15, got %s" % $sum).throw();
    }

    // - direct equality -
    if (!([1,2,3] == [1,2,3]))
    {
      new Exception("[1,2,3] == [1,2,3]").throw();
    }
    if ([1,2,3] == [1,2,4])
    {
      new Exception("[1,2,3] == [1,2,4]").throw();
    }
    if ([1,2,3] != [1,2,3])
    {
      new Exception("[1,2,3] != [1,2,3]").throw();
    }
    // - cross-type compare -
    if ([1,2,3] == 10)
    {
      new Exception("array == int").throw();
    }

    // - to_string#0 / to_string#1 -
    if ([1,2,3,4,5].to_string() != "[1,2,3,4,5]")
    {
      new Exception("to_string(): got %s" % [1,2,3,4,5].to_string()).throw();
    }
    if ([1,2,3].to_string("-") != "1-2-3")
    {
      new Exception("to_string(\"-\"): got %s" % [1,2,3].to_string("-")).throw();
    }

    // - length consistency across operations -
    a = new Array();
    if (a.length() != 0) { new Exception("len 0").throw(); }
    a.push(1);
    if (a.length() != 1) { new Exception("len 1").throw(); }
    a.push(2);
    a.push(3);
    if (a.length() != 3) { new Exception("len 3").throw(); }
    a.pop();
    if (a.length() != 2) { new Exception("len 2 after pop").throw(); }
  }/*}}}*/
}
