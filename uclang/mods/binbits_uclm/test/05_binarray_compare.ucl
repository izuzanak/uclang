
import binbits;

class Main
{
  static public main(argv)
  {/*{{{*/

    // - compare equal arrays -
    arr_a = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    arr_b = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    if (arr_a.compare(arr_b) != 0)
    {
      new Exception("compare equal: expected 0, got %d" % arr_a.compare(arr_b)).throw();
    }

    // - compare fewer elements -
    arr_a = new BinArray(BinArray.TYPE_INT32,[1,2]);
    arr_b = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    if (arr_a.compare(arr_b) >= 0)
    {
      new Exception("compare fewer: expected < 0, got %d" % arr_a.compare(arr_b)).throw();
    }

    // - compare more elements -
    if (arr_b.compare(arr_a) <= 0)
    {
      new Exception("compare more: expected > 0, got %d" % arr_b.compare(arr_a)).throw();
    }

    // - compare element-wise -
    arr_a = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    arr_b = new BinArray(BinArray.TYPE_INT32,[1,2,4]);
    if (arr_a.compare(arr_b) >= 0)
    {
      new Exception("compare element-wise: expected < 0, got %d" % arr_a.compare(arr_b)).throw();
    }

    // - compare self -
    arr_a = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    if (arr_a.compare(arr_a) != 0)
    {
      new Exception("compare self: expected 0, got %d" % arr_a.compare(arr_a)).throw();
    }

    // - == operator equal -
    arr_a = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    arr_b = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    if (arr_a == arr_b != 1)
    {
      new Exception("== equal: expected 1").throw();
    }

    // - == operator unequal -
    arr_b = new BinArray(BinArray.TYPE_INT32,[1,2,4]);
    if (arr_a == arr_b != 0)
    {
      new Exception("== unequal: expected 0").throw();
    }

    // - != operator different -
    if (arr_a != arr_b != 1)
    {
      new Exception("!= different: expected 1").throw();
    }

    // - != operator same -
    arr_b = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    if (arr_a != arr_b != 0)
    {
      new Exception("!= same: expected 0").throw();
    }

    // - + concatenation -
    arr_a = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    concat = arr_a + [4,5];
    if ($concat != "[1,2,3,4,5]")
    {
      new Exception("+ concat: expected [1,2,3,4,5], got %s" % $concat).throw();
    }

    // - + does not modify original -
    if ($arr_a != "[1,2,3]")
    {
      new Exception("+ modified original: got %s" % $arr_a).throw();
    }

    // - += in-place append -
    arr_a = new BinArray(BinArray.TYPE_INT32,[1,2]);
    arr_a += [3,4];
    if ($arr_a != "[1,2,3,4]")
    {
      new Exception("+= append: expected [1,2,3,4], got %s" % $arr_a).throw();
    }

    // - + with empty -
    arr_a = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    concat = arr_a + [];
    if ($concat != "[1,2,3]")
    {
      new Exception("+ empty: expected [1,2,3], got %s" % $concat).throw();
    }

    // - compare double arrays -
    arr_a = new BinArray(BinArray.TYPE_DOUBLE,[1.0,2.0]);
    arr_b = new BinArray(BinArray.TYPE_DOUBLE,[1.0,2.0]);
    if (arr_a.compare(arr_b) != 0)
    {
      new Exception("compare double equal: expected 0, got %d" % arr_a.compare(arr_b)).throw();
    }

    // - compare double element-wise -
    arr_b = new BinArray(BinArray.TYPE_DOUBLE,[1.0,3.0]);
    if (arr_a.compare(arr_b) >= 0)
    {
      new Exception("compare double element: expected < 0, got %d" % arr_a.compare(arr_b)).throw();
    }
  }/*}}}*/
}
