
import binbits;

class Main
{
  static public main(argv)
  {/*{{{*/

    // - construct TYPE_INT32 empty -
    arr = new BinArray(BinArray.TYPE_INT32);
    if (arr.length() != 0)
    {
      new Exception("INT32 empty: expected length 0, got %d" % arr.length()).throw();
    }

    // - construct TYPE_UINT32 empty -
    arr = new BinArray(BinArray.TYPE_UINT32);
    if (arr.length() != 0)
    {
      new Exception("UINT32 empty: expected length 0, got %d" % arr.length()).throw();
    }

    // - construct TYPE_FLOAT empty -
    arr = new BinArray(BinArray.TYPE_FLOAT);
    if (arr.length() != 0)
    {
      new Exception("FLOAT empty: expected length 0, got %d" % arr.length()).throw();
    }

    // - construct TYPE_DOUBLE empty -
    arr = new BinArray(BinArray.TYPE_DOUBLE);
    if (arr.length() != 0)
    {
      new Exception("DOUBLE empty: expected length 0, got %d" % arr.length()).throw();
    }

    // - type constants are distinct -
    if (BinArray.TYPE_INT32 == BinArray.TYPE_UINT32
     || BinArray.TYPE_INT32 == BinArray.TYPE_FLOAT
     || BinArray.TYPE_INT32 == BinArray.TYPE_DOUBLE
     || BinArray.TYPE_UINT32 == BinArray.TYPE_FLOAT
     || BinArray.TYPE_UINT32 == BinArray.TYPE_DOUBLE
     || BinArray.TYPE_FLOAT == BinArray.TYPE_DOUBLE)
    {
      new Exception("type constants are not all distinct").throw();
    }

    // - construct TYPE_INT32 from array -
    arr = new BinArray(BinArray.TYPE_INT32,[10,20,30]);
    if (arr.length() != 3)
    {
      new Exception("INT32 from array: expected length 3, got %d" % arr.length()).throw();
    }
    if (arr.item(0).value() != 10 || arr.item(1).value() != 20 || arr.item(2).value() != 30)
    {
      new Exception("INT32 from array: element mismatch").throw();
    }

    // - construct TYPE_UINT32 from array -
    arr = new BinArray(BinArray.TYPE_UINT32,[100,200]);
    if (arr.length() != 2)
    {
      new Exception("UINT32 from array: expected length 2, got %d" % arr.length()).throw();
    }

    // - construct TYPE_FLOAT from array -
    arr = new BinArray(BinArray.TYPE_FLOAT,[1.5,2.5]);
    if (arr.length() != 2)
    {
      new Exception("FLOAT from array: expected length 2, got %d" % arr.length()).throw();
    }

    // - construct TYPE_DOUBLE from array -
    arr = new BinArray(BinArray.TYPE_DOUBLE,[3.14,2.72]);
    if (arr.length() != 2)
    {
      new Exception("DOUBLE from array: expected length 2, got %d" % arr.length()).throw();
    }

    // - construct from empty array -
    arr = new BinArray(BinArray.TYPE_INT32,[]);
    if (arr.length() != 0)
    {
      new Exception("from empty array: expected length 0, got %d" % arr.length()).throw();
    }

    // - to_string empty array -
    arr = new BinArray(BinArray.TYPE_INT32);
    if ($arr != "[]")
    {
      new Exception("to_string empty: expected [], got %s" % $arr).throw();
    }

    // - to_string INT32 array -
    arr = new BinArray(BinArray.TYPE_INT32,[1,2,3]);
    if ($arr != "[1,2,3]")
    {
      new Exception("to_string INT32: expected [1,2,3], got %s" % $arr).throw();
    }

    // - to_string UINT32 array -
    arr = new BinArray(BinArray.TYPE_UINT32,[1,2,3]);
    if ($arr != "[1,2,3]")
    {
      new Exception("to_string UINT32: expected [1,2,3], got %s" % $arr).throw();
    }

    // - to_string DOUBLE array -
    arr = new BinArray(BinArray.TYPE_DOUBLE,[1.5,2.5]);
    if ($arr != "[1.500000,2.500000]")
    {
      new Exception("to_string DOUBLE: expected [1.500000,2.500000], got %s" % $arr).throw();
    }
  }/*}}}*/
}
