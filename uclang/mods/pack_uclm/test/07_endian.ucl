
import pack;

class Main
{
  static public main(argv)
  {/*{{{*/

    // - big-endian unsigned short roundtrip -
    result = Pack.decode(">H",Pack.code(">H",[0x0102]));
    if (result[0] != 0x0102)
    {
      new Exception(">H roundtrip: expected 0x0102, got %s" % $result[0]).throw();
    }

    // - little-endian unsigned short roundtrip -
    result = Pack.decode("<H",Pack.code("<H",[0x0102]));
    if (result[0] != 0x0102)
    {
      new Exception("<H roundtrip: expected 0x0102, got %s" % $result[0]).throw();
    }

    // - native endian unsigned int roundtrip -
    result = Pack.decode("=I",Pack.code("=I",[0x12345678]));
    if (result[0] != 0x12345678)
    {
      new Exception("=I roundtrip: expected 0x12345678, got %s" % $result[0]).throw();
    }

    // - cross-endian mismatch: big to little -
    data = Pack.code(">H",[0x0102]);
    result = Pack.decode("<H",data);
    if (result[0] != 0x0201)
    {
      new Exception(">H decoded as <H: expected 0x0201, got %s" % $result[0]).throw();
    }

    // - cross-endian mismatch: little to big -
    data = Pack.code("<H",[0x0102]);
    result = Pack.decode(">H",data);
    if (result[0] != 0x0201)
    {
      new Exception("<H decoded as >H: expected 0x0201, got %s" % $result[0]).throw();
    }

    // - big-endian int roundtrip -
    result = Pack.decode(">i",Pack.code(">i",[-999999]));
    if (result[0] != -999999)
    {
      new Exception(">i roundtrip: got %s" % $result[0]).throw();
    }

    // - little-endian int roundtrip -
    result = Pack.decode("<i",Pack.code("<i",[-999999]));
    if (result[0] != -999999)
    {
      new Exception("<i roundtrip: got %s" % $result[0]).throw();
    }

    // - big-endian long long roundtrip -
    result = Pack.decode(">q",Pack.code(">q",[123456789012345]));
    if (result[0] != 123456789012345)
    {
      new Exception(">q roundtrip: got %s" % $result[0]).throw();
    }

    // - little-endian long long roundtrip -
    result = Pack.decode("<q",Pack.code("<q",[123456789012345]));
    if (result[0] != 123456789012345)
    {
      new Exception("<q roundtrip: got %s" % $result[0]).throw();
    }

    // - big-endian float roundtrip -
    result = Pack.decode(">f",Pack.code(">f",[1.0]));
    if (result[0] != 1.0)
    {
      new Exception(">f roundtrip: got %s" % $result[0]).throw();
    }

    // - little-endian float roundtrip -
    result = Pack.decode("<f",Pack.code("<f",[1.0]));
    if (result[0] != 1.0)
    {
      new Exception("<f roundtrip: got %s" % $result[0]).throw();
    }

    // - big-endian double roundtrip -
    result = Pack.decode(">d",Pack.code(">d",[3.141592653589793]));
    if (result[0] != 3.141592653589793)
    {
      new Exception(">d roundtrip: got %s" % $result[0]).throw();
    }

    // - little-endian double roundtrip -
    result = Pack.decode("<d",Pack.code("<d",[3.141592653589793]));
    if (result[0] != 3.141592653589793)
    {
      new Exception("<d roundtrip: got %s" % $result[0]).throw();
    }

    // - multi-value big-endian QHH roundtrip -
    result = Pack.decode(">QHH",Pack.code(">QHH",[123456789012345,42,7]));
    if (result[0] != 123456789012345)
    {
      new Exception(">QHH[0]: got %s" % $result[0]).throw();
    }
    if (result[1] != 42)
    {
      new Exception(">QHH[1]: got %s" % $result[1]).throw();
    }
    if (result[2] != 7)
    {
      new Exception(">QHH[2]: got %s" % $result[2]).throw();
    }

    // - multi-value little-endian QHH roundtrip -
    result = Pack.decode("<QHH",Pack.code("<QHH",[123456789012345,42,7]));
    if (result[0] != 123456789012345)
    {
      new Exception("<QHH[0]: got %s" % $result[0]).throw();
    }
    if (result[1] != 42)
    {
      new Exception("<QHH[1]: got %s" % $result[1]).throw();
    }
    if (result[2] != 7)
    {
      new Exception("<QHH[2]: got %s" % $result[2]).throw();
    }

    // - native endian multi-value roundtrip -
    result = Pack.decode("=BHI",Pack.code("=BHI",[0xab,0x1234,0x56789abc]));
    if (result[0] != 0xab)
    {
      new Exception("=BHI[0]: got %s" % $result[0]).throw();
    }
    if (result[1] != 0x1234)
    {
      new Exception("=BHI[1]: got %s" % $result[1]).throw();
    }
    if (result[2] != 0x56789abc)
    {
      new Exception("=BHI[2]: got %s" % $result[2]).throw();
    }

    // - endian with length-prefixed string roundtrip -
    result = Pack.decode("<Hs",Pack.code("<Hs",[42,"hello"]));
    if (result[0] != 42)
    {
      new Exception("<Hs[0]: got %s" % $result[0]).throw();
    }
    if (result[1] != "hello")
    {
      new Exception("<Hs[1]: got %s" % result[1]).throw();
    }

    // - endian with zero-terminated string roundtrip -
    result = Pack.decode(">Hz",Pack.code(">Hz",[0x1234,"hello"]));
    if (result[0] != 0x1234)
    {
      new Exception(">Hz[0]: got %s" % $result[0]).throw();
    }
    if (result[1] != "hello")
    {
      new Exception(">Hz[1]: got %s" % result[1]).throw();
    }

    // - real-world pattern: little-endian 7 unsigned ints -
    vals = [1,2,3,4,5,6,7];
    result = Pack.decode("<7I",Pack.code("<7I",vals));
    idx = 0;
    do {
      if (result[idx] != vals[idx])
      {
        new Exception("<7I[%d]: expected %s, got %s" % [idx,$vals[idx],$result[idx]]).throw();
      }
    } while(++idx < 7);
  }/*}}}*/
}
