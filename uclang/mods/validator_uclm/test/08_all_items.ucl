
import containers;
import validator;

class Main
{
  static public main(argv)
  {/*{{{*/

    // - all-items array pass -
    schema = new Dict(["all_int", ["all-items", ["==", 10]]]);
    v = new Validator(schema);
    v.validate("all_int", [10, 10, 10]);

    // - all-items array fail with stack -
    caught = 0;
    try {
      v.validate("all_int", [10, 10, 11]);
    }
    catch (e)
    {
      caught = 1;
      if (v.props_stack() != ["all_int", "all-items", 2, "=="])
      {
        new Exception("expected props_stack [all_int,all-items,2,==], got %s" % $v.props_stack()).throw();
      }
      if (v.value_stack() != [2])
      {
        new Exception("expected value_stack [2], got %s" % $v.value_stack()).throw();
      }
    }
    if (caught != 1)
    {
      new Exception("all-items should reject array with 11").throw();
    }

    // - all-items dict pass -
    schema = new Dict(["all_str", ["all-items", ["type", type String]]]);
    v = new Validator(schema);
    v.validate("all_str", new Dict(["a", "hello", "b", "world"]));

    // - all-items dict fail with stack -
    caught = 0;
    try {
      v.validate("all_str", new Dict(["a", "hello", "b", 42]));
    }
    catch (e)
    {
      caught = 1;
      if (v.props_stack() != ["all_str", "all-items", "b", "type"])
      {
        new Exception("expected props_stack [all_str,all-items,b,type], got %s" % $v.props_stack()).throw();
      }
      if (v.value_stack() != ["b"])
      {
        new Exception("expected value_stack [b], got %s" % $v.value_stack()).throw();
      }
    }
    if (caught != 1)
    {
      new Exception("all-items should reject dict with int value").throw();
    }

    // - all-items empty array pass -
    v.validate("all_str", []);

    // - all-items empty dict pass -
    v.validate("all_str", new Dict());

    // - all-items with dict, all equal 10 (from C test) -
    schema = new Dict(["test", ["all-items", ["==", 10]]]);
    v = new Validator(schema);
    v.validate("test", new Dict(["first", 10, "second", 10, "third", 10]));

    // - all-items dict fail (third != 10) -
    caught = 0;
    try {
      v.validate("test", new Dict(["first", 10, "second", 10, "third", 11]));
    }
    catch (e)
    {
      caught = 1;
      if (v.props_stack() != ["test", "all-items", "third", "=="])
      {
        new Exception("expected props_stack [test,all-items,third,==], got %s" % $v.props_stack()).throw();
      }
      if (v.value_stack() != ["third"])
      {
        new Exception("expected value_stack [third], got %s" % $v.value_stack()).throw();
      }
    }
    if (caught != 1)
    {
      new Exception("all-items dict should reject third=11").throw();
    }

    // - all-items with ref to another entry -
    schema = new Dict([
      "int_rule", ["type", type Integer],
      "arr_ref", ["all-items", "int_rule"]
    ]);
    v = new Validator(schema);
    v.validate("arr_ref", [1, 2, 3]);

    caught = 0;
    try {
      v.validate("arr_ref", [1, "two", 3]);
    }
    catch (e)
    {
      caught = 1;
    }
    if (caught != 1)
    {
      new Exception("all-items ref should reject string in array").throw();
    }
  }/*}}}*/
}
