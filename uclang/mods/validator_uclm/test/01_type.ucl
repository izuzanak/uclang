
import containers;
import validator;

class Main
{
  static public main(argv)
  {/*{{{*/

    // - type Integer pass -
    schema = new Dict(["entry",["type",type Integer]]);
    v = new Validator(schema);
    v.validate("entry",42);

    // - type String pass -
    schema = new Dict(["entry",["type",type String]]);
    v = new Validator(schema);
    v.validate("entry","hello");

    // - type Float pass -
    schema = new Dict(["entry",["type",type Float]]);
    v = new Validator(schema);
    v.validate("entry",3.14);

    // - type Array pass -
    schema = new Dict(["entry",["type",type Array]]);
    v = new Validator(schema);
    v.validate("entry",[1,2,3]);

    // - type Dict pass -
    schema = new Dict(["entry",["type",type Dict]]);
    v = new Validator(schema);
    v.validate("entry",new Dict(["a",1]));

    // - type Integer fail with String -
    schema = new Dict(["entry",["type",type Integer]]);
    v = new Validator(schema);
    caught = 0;
    try {
      v.validate("entry","not_an_int");
    }
    catch (e)
    {
      caught = 1;
    }
    if (caught != 1)
    {
      new Exception("type Integer should reject String").throw();
    }

    // - type String fail with Integer -
    schema = new Dict(["entry",["type",type String]]);
    v = new Validator(schema);
    caught = 0;
    try {
      v.validate("entry",42);
    }
    catch (e)
    {
      caught = 1;
    }
    if (caught != 1)
    {
      new Exception("type String should reject Integer").throw();
    }

    // - type Float fail with String -
    schema = new Dict(["entry",["type",type Float]]);
    v = new Validator(schema);
    caught = 0;
    try {
      v.validate("entry","not_a_float");
    }
    catch (e)
    {
      caught = 1;
    }
    if (caught != 1)
    {
      new Exception("type Float should reject String").throw();
    }

    // - type with non-Type prop value must throw -
    schema = new Dict(["entry",["type","Integer"]]);
    v = new Validator(schema);
    caught = 0;
    try {
      v.validate("entry",42);
    }
    catch (e)
    {
      caught = 1;
    }
    if (caught != 1)
    {
      new Exception("type with string prop value should throw").throw();
    }
  }/*}}}*/
}
