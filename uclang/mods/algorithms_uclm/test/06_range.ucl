
import containers;
import algorithms;

class Main
{
  static public main(argv)
  {/*{{{*/

    // - bounded ascending -
    result = new Range(0,4)[::];
    if (result != [0,1,2,3,4])
    {
      new Exception("Range(0,4): expected [0,1,2,3,4], got %s" % $result).throw();
    }

    // - bounded descending (auto-detect) -
    result = new Range(5,1)[::];
    if (result != [5,4,3,2,1])
    {
      new Exception("Range(5,1): expected [5,4,3,2,1], got %s" % $result).throw();
    }

    // - single element range -
    result = new Range(3,3)[::];
    if (result != [3])
    {
      new Exception("Range(3,3): expected [3], got %s" % $result).throw();
    }

    // - custom step ascending -
    result = new Range(0,10,2)[::];
    if (result != [0,2,4,6,8,10])
    {
      new Exception("Range(0,10,2): expected [0,2,4,6,8,10], got %s" % $result).throw();
    }

    // - custom step descending -
    result = new Range(10,0,-3)[::];
    if (result != [10,7,4,1])
    {
      new Exception("Range(10,0,-3): expected [10,7,4,1], got %s" % $result).throw();
    }

    // - manual next_item iteration -
    r = new Range(1,3);
    v1 = r.next_item();
    v2 = r.next_item();
    v3 = r.next_item();
    v4 = r.next_item();
    if (v1 != 1 || v2 != 2 || v3 != 3)
    {
      new Exception("next_item: expected 1,2,3 got %s,%s,%s" % [$v1,$v2,$v3]).throw();
    }
    if (Blank != v4)
    {
      new Exception("next_item exhausted: expected Blank, got %s" % $v4).throw();
    }

    // - infinite range (partial consumption) -
    r = new Range(0);
    vals = [];
    idx = 0;
    while (idx < 5)
    {
      vals.push(r.next_item());
      idx += 1;
    }
    if (vals != [0,1,2,3,4])
    {
      new Exception("infinite Range: expected [0,1,2,3,4], got %s" % $vals).throw();
    }

    // - to_string returns class name -
    if ($Range != "Range")
    {
      new Exception("to_string: expected Range, got %s" % $Range).throw();
    }

    // - for-each iteration -
    sum = 0;
    for (v <- new Range(1,5))
    {
      sum += v;
    }
    if (sum != 15)
    {
      new Exception("for-each sum: expected 15, got %d" % sum).throw();
    }
  }/*}}}*/
}
