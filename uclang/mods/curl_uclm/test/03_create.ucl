
import sys;
import http;
import curl;

class Main
{
  public Main() {}

  // - HttpServer connection callback (1 arg) -
  public on_conn(a_conn) {}

  // - CurlMulti completion callback (1 arg) -
  public on_done(a_result) {}

  static public main(argv)
  {/*{{{*/
    obj = new Main();
    port = 19500 + (Sys.getpid() % 1000);

    // - construct HttpServer with 4-arg form: (flags,port,delegate,opts) -
    server = new HttpServer(0,port,
      new Delegate(obj,"on_conn",1),[]);

    // - HttpServer to_string -
    if ($server != "HttpServer")
    {
      new Exception("server to_string: expected HttpServer, got %s" % $server).throw();
    }

    // - get_fds returns Array with even count (fd/flags pairs) -
    fds = server.get_fds();
    if ($(type fds) != "Array")
    {
      new Exception("get_fds: expected Array, got %s" % $(type fds)).throw();
    }
    if (fds.length() % 2 != 0)
    {
      new Exception("get_fds: expected even count, got %d" % fds.length()).throw();
    }

    // - timeout returns Integer -
    tmo = server.timeout();
    if (type tmo != type Integer)
    {
      new Exception("server.timeout: expected Integer, got %s" % $(type tmo)).throw();
    }

    // - process(0) does not throw -
    server.process(0);

    // - construct CurlMulti -
    cm = new CurlMulti(new Delegate(obj,"on_done",1));

    // - CurlMulti to_string -
    if ($cm != "CurlMulti")
    {
      new Exception("cm to_string: expected CurlMulti, got %s" % $cm).throw();
    }

    // - empty CurlMulti get_fds returns empty Array -
    cm_fds = cm.get_fds();
    if ($(type cm_fds) != "Array")
    {
      new Exception("cm.get_fds: expected Array, got %s" % $(type cm_fds)).throw();
    }
    if (cm_fds.length() != 0)
    {
      new Exception("cm.get_fds (no requests): expected empty, got %d items" % cm_fds.length()).throw();
    }

    // - empty CurlMulti timeout returns Integer -
    cm_tmo = cm.timeout();
    if (type cm_tmo != type Integer)
    {
      new Exception("cm.timeout: expected Integer, got %s" % $(type cm_tmo)).throw();
    }

    // - process on empty CurlMulti does not throw -
    cm.process();

    // - CurlMultiRequest, CurlResult class to_string -
    if ($CurlMultiRequest != "CurlMultiRequest")
    {
      new Exception("CurlMultiRequest to_string: expected CurlMultiRequest, got %s" % $CurlMultiRequest).throw();
    }
    if ($CurlResult != "CurlResult")
    {
      new Exception("CurlResult to_string: expected CurlResult, got %s" % $CurlResult).throw();
    }

    // - HttpResp construction -
    resp = new HttpResp(HttpResp.FROM_STRING,"hello");
    if ($resp != "HttpResp")
    {
      new Exception("resp to_string: expected HttpResp, got %s" % $resp).throw();
    }

    // - cleanup: stop server, free CurlMulti -
    server.stop();
    free cm;
  }/*}}}*/
}
