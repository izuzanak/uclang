
import time;

class Main
{
  static public main(argv)
  {/*{{{*/

    // - datetime array for 2000/01/01 10:30:25 -
    t = new Time("20000101103025");
    dt = t.datetime();

    if (dt.length() != 10)
    {
      new Exception("datetime: expected 10 elements, got %s" % $dt.length()).throw();
    }

    expected = [2000,1,1,6,10,30,25,0,0,0];
    labels = ["year","month","day","wday","hour","min","sec","msec","usec","nsec"];

    idx = 0;
    for (label <- labels)
    {
      if (dt[idx] != expected[idx])
      {
        new Exception("datetime %s: expected %s, got %s" % [label,$expected[idx],$dt[idx]]).throw();
      }
      idx += 1;
    }

    // - day_of_week: 2000/01/01 is Saturday (6) -
    if (t.day_of_week() != 6)
    {
      new Exception("day_of_week 2000/01/01: expected 6, got %s" % $t.day_of_week()).throw();
    }

    // - day_of_week: 1970/01/01 is Thursday (4) -
    t = new Time("19700101000000");
    if (t.day_of_week() != 4)
    {
      new Exception("day_of_week 1970/01/01: expected 4, got %s" % $t.day_of_week()).throw();
    }

    // - day_of_week: 1970/01/05 is Monday (1) -
    t = new Time("19700105000000");
    if (t.day_of_week() != 1)
    {
      new Exception("day_of_week 1970/01/05: expected 1, got %s" % $t.day_of_week()).throw();
    }
  }/*}}}*/
}
