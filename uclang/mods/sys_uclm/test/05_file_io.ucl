
import sys;

class Main
{
  static public main(argv)
  {/*{{{*/

    pid = Sys.getpid();
    tmp_file = "/tmp/ucltest_sys_05_%d.txt" % pid;
    content = "Hello world!\nSecond line\n";

    // - write file -
    file = new File(tmp_file,"w");
    file.write(content);
    file.flush();
    file.close();

    // - Sys.open returns File -
    file = Sys.open(tmp_file,"r");
    if ($file != "File")
    {
      new Exception("Sys.open to_string: expected File, got %s" % $file).throw();
    }
    file.close();

    // - tell initially 0 -
    file = new File(tmp_file,"r");
    if (file.tell() != 0)
    {
      new Exception("tell: expected 0, got %d" % file.tell()).throw();
    }

    // - read all -
    data = file.read();
    if (data != content)
    {
      new Exception("read: expected %s, got %s" % [content,data]).throw();
    }
    file.close();

    // - seek SEEK_SET -
    file = new File(tmp_file,"r");
    file.seek(5,File.SEEK_SET);
    if (file.tell() != 5)
    {
      new Exception("seek SET: tell expected 5, got %d" % file.tell()).throw();
    }

    // - seek SEEK_CUR -
    file.seek(3,File.SEEK_CUR);
    if (file.tell() != 8)
    {
      new Exception("seek CUR: tell expected 8, got %d" % file.tell()).throw();
    }

    // - seek SEEK_END -
    file.seek(0,File.SEEK_END);
    if (file.tell() != content.length())
    {
      new Exception("seek END: tell expected %d, got %d" % [content.length(),file.tell()]).throw();
    }
    file.close();

    // - readln (strips trailing newline) -
    file = new File(tmp_file,"r");
    line = file.readln();
    if (line != "Hello world!")
    {
      new Exception("readln: expected Hello world!, got %s" % $line).throw();
    }
    line = file.readln();
    if (line != "Second line")
    {
      new Exception("readln 2: expected Second line, got %s" % $line).throw();
    }
    file.close();

    // - read(N) exact bytes -
    file = new File(tmp_file,"r");
    data = file.read(5);
    if (data != "Hello")
    {
      new Exception("read(5): expected Hello, got %s" % data).throw();
    }
    file.close();

    // - read_max -
    file = new File(tmp_file,"r");
    data = file.read_max(1024);
    if (data != content)
    {
      new Exception("read_max: content mismatch").throw();
    }
    file.close();

    // - get_fd -
    file = new File(tmp_file,"r");
    fd = file.get_fd();
    if (fd < 0)
    {
      new Exception("get_fd: expected non-negative, got %d" % fd).throw();
    }
    file.close();

    // - write_close -
    file = new File(tmp_file,"w");
    file.write_close("write_close_data");

    // - read_close -
    file = new File(tmp_file,"r");
    data = file.read_close();
    if (data != "write_close_data")
    {
      new Exception("read_close: expected write_close_data, got %s" % data).throw();
    }

    // - File constants -
    if ($File.stdin != "File")
    {
      new Exception("File.stdin: expected File, got %s" % $File.stdin).throw();
    }
    if ($File.stdout != "File")
    {
      new Exception("File.stdout: expected File, got %s" % $File.stdout).throw();
    }
    if ($File.stderr != "File")
    {
      new Exception("File.stderr: expected File, got %s" % $File.stderr).throw();
    }

    // - SEEK constants are integers -
    seek_set = File.SEEK_SET;
    seek_cur = File.SEEK_CUR;
    seek_end = File.SEEK_END;
    if (seek_set != 0)
    {
      new Exception("SEEK_SET: expected 0, got %d" % seek_set).throw();
    }
    if (seek_cur != 1)
    {
      new Exception("SEEK_CUR: expected 1, got %d" % seek_cur).throw();
    }
    if (seek_end != 2)
    {
      new Exception("SEEK_END: expected 2, got %d" % seek_end).throw();
    }

    // - iteration over file lines -
    file = new File(tmp_file,"w");
    file.write_close("line1\nline2\nline3\n");

    file = new File(tmp_file,"r");
    lines = [];
    for (line <- file)
    {
      lines.push(line);
    }
    file.close();

    if (lines.length() != 3)
    {
      new Exception("iteration: expected 3 lines, got %d" % lines.length()).throw();
    }
    if (lines[0] != "line1")
    {
      new Exception("iteration line 0: expected line1, got %s" % $lines[0]).throw();
    }

    // - error: open non-existent for reading -
    caught = 0;
    try {
      new File("/tmp/ucltest_nonexistent_%d" % pid,"r");
    }
    catch (e)
    {
      caught = 1;
    }
    if (caught != 1)
    {
      new Exception("open non-existent did not throw").throw();
    }

    // - error: write on closed file -
    file = new File(tmp_file,"w");
    file.close();
    caught = 0;
    try {
      file.write("data");
    }
    catch (e)
    {
      caught = 1;
    }
    if (caught != 1)
    {
      new Exception("write on closed file did not throw").throw();
    }

    // - error: read on closed file -
    file = new File(tmp_file,"r");
    file.close();
    caught = 0;
    try {
      file.read();
    }
    catch (e)
    {
      caught = 1;
    }
    if (caught != 1)
    {
      new Exception("read on closed file did not throw").throw();
    }

    // - cleanup -
    Sys.remove(tmp_file);
  }/*}}}*/
}
