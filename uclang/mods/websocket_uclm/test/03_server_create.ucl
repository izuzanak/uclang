
import sys;
import websocket;

class Main
{
  public Main() {}

  public on_ws_callback(a_conn)
  {/*{{{*/
  }/*}}}*/

  static public main(argv)
  {/*{{{*/
    obj = new Main();
    port = 19300 + (Sys.getpid() % 1000);

    ctx = new WsContext("127.0.0.1",port,
      ["test-protocol",new Delegate(obj,"on_ws_callback",1)]);

    // - WsContext to_string -
    if ($ctx != "WsContext")
    {
      new Exception("ctx to_string: expected WsContext, got %s" % $ctx).throw();
    }

    // - WsConn to_string -
    if ($WsConn != "WsConn")
    {
      new Exception("WsConn to_string: expected WsConn, got %s" % $WsConn).throw();
    }

    // - WsClient to_string -
    if ($WsClient != "WsClient")
    {
      new Exception("WsClient to_string: expected WsClient, got %s" % $WsClient).throw();
    }

    // - version returns non-empty string -
    ver = WsContext.version();
    if (ver.length() == 0)
    {
      new Exception("version: expected non-empty string").throw();
    }

    // - user_data initial value is Blank -
    ud = ctx.user_data();
    if (Blank != ud)
    {
      new Exception("user_data: expected Blank initially").throw();
    }

    // - user_data is assignable reference -
    ctx.user_data() = [1,2,3];
    ud2 = ctx.user_data();
    if ($ud2 != "[1,2,3]")
    {
      new Exception("user_data: expected [1,2,3], got %s" % $ud2).throw();
    }

    // - get_fds returns array with fd/events pairs -
    fds = ctx.get_fds();
    if (fds.length() < 2)
    {
      new Exception("get_fds: expected >= 2 elements, got %d" % fds.length()).throw();
    }

    if (fds.length() % 2 != 0)
    {
      new Exception("get_fds: expected even count, got %d" % fds.length()).throw();
    }

    // - protocol_idx -
    prot_idx = ctx.protocol_idx("test-protocol");
    if (prot_idx != 0)
    {
      new Exception("protocol_idx: expected 0, got %d" % prot_idx).throw();
    }

    // - process(0) should not throw -
    ctx.process(0);

    // - callback_on_writable with valid protocol index -
    ctx.callback_on_writable(0);

    // - release -
    free ctx;
  }/*}}}*/
}
