
import sys;
import containers;
import algorithms;
import websocket;
import epoll;

class Main
{
  public Main()
  {/*{{{*/
    m_epoll = new Epoll(Epoll.CLOEXEC);
    m_poll_callbacks = new Dict();
    m_ws_fd_set = new Set();
  }/*}}}*/

  // - shared state -
  static client_established = 0;
  static server_established = 0;
  static received = [];
  static client_send_queue = new Queue();

  public m_epoll;
  public m_poll_callbacks;
  public m_ws_fd_set;
  public m_ctx;
  public m_ws_client;

  // - websocket protocol callback -
  public on_ws_event(a_conn)
  {/*{{{*/
    reason = a_conn.reason();

    if (reason == WsConn.CB_ESTABLISHED)
    {
      server_established = 1;
    }
    else if (reason == WsConn.CB_CLIENT_ESTABLISHED)
    {
      client_established = 1;

      // - verify protocol_name -
      if (a_conn.protocol_name() != "echo-protocol")
      {
        new Exception("client protocol_name: expected echo-protocol, got %s" % a_conn.protocol_name()).throw();
      }

      // - verify user_data -
      if ($a_conn.user_data() != "client-ud")
      {
        new Exception("client user_data: expected client-ud, got %s" % $a_conn.user_data()).throw();
      }
    }
    else if (reason == WsConn.CB_RECEIVE)
    {
      // - server received data: echo back directly -
      data = a_conn.received_data();
      a_conn.write("ECHO:%s" % data);
    }
    else if (reason == WsConn.CB_CLIENT_RECEIVE)
    {
      // - client received echo -
      received.push($a_conn.received_data());
    }
    else if (reason == WsConn.CB_CLIENT_WRITEABLE)
    {
      // - write queued client messages -
      if (client_send_queue.length() > 0)
      {
        a_conn.write(client_send_queue.next());
      }
    }
  }/*}}}*/

  // - fd event handler -
  public on_ws_fd_event(a_fd,a_event)
  {/*{{{*/
    m_ctx.process(0);
    this.poll_set_update();
  }/*}}}*/

  // - poll management -
  public poll_fd_add(a_fd,a_events,a_callback)
  {/*{{{*/
    m_epoll.add(a_fd,a_events);
    m_poll_callbacks[a_fd] = a_callback;
  }/*}}}*/

  public poll_fd_remove(a_fd)
  {/*{{{*/
    m_epoll.del(a_fd);
    m_poll_callbacks.remove_key(a_fd);
  }/*}}}*/

  public poll_set_update()
  {/*{{{*/
    s_fds = m_ctx.get_fds();
    new_set = new Set(Algo.tuple_zip([s_fds[::2],s_fds[1::2]]));

    // - remove old or modified fds -
    for (pollfd <- m_ws_fd_set - new_set)
    {
      m_epoll.del(pollfd[0]);
      m_poll_callbacks.remove_key(pollfd[0]);
    }

    // - add new or modified fds -
    for (pollfd <- new_set - m_ws_fd_set)
    {
      m_epoll.add(pollfd[0],pollfd[1]);
      m_poll_callbacks[pollfd[0]] = new Delegate(this,"on_ws_fd_event",2);
    }

    m_ws_fd_set = new_set;
  }/*}}}*/

  static public main(argv)
  {/*{{{*/
    obj = new Main();
    port = 19400 + (Sys.getpid() % 1000);

    obj.m_ctx = new WsContext("127.0.0.1",port,
      ["echo-protocol",new Delegate(obj,"on_ws_event",1)]);

    // - register initial fds -
    obj.poll_set_update();

    // - create client connection -
    obj.m_ws_client = obj.m_ctx.client(
      "127.0.0.1",port,"/","echo-protocol","client-ud");

    // - verify WsClient type -
    if ($obj.m_ws_client != "WsClient")
    {
      new Exception("ws_client to_string: expected WsClient, got %s" % $obj.m_ws_client).throw();
    }

    // - initial process + fd update after client creation -
    obj.m_ctx.process(0);
    obj.poll_set_update();

    test_messages = ["hello","world","test123"];
    messages_sent = 0;
    iterations = 0;

    while (received.length() < test_messages.length() and iterations < 500)
    {
      // - wait for events -
      events = obj.m_epoll.wait(1,50);

      if (Blank != events)
      {
        obj.m_poll_callbacks[events[0]].call(events);
      }

      // - send messages after client connects -
      if (client_established == 1 and messages_sent < test_messages.length())
      {
        client_send_queue.insert(test_messages[messages_sent]);
        obj.m_ws_client.callback_on_writable();
        messages_sent += 1;

        // - process to trigger writable callback -
        obj.m_ctx.process(0);
        obj.poll_set_update();
      }

      iterations += 1;
    }

    // - verify connection events -
    if (server_established != 1)
    {
      new Exception("server_established: expected 1, got %d" % server_established).throw();
    }

    if (client_established != 1)
    {
      new Exception("client did not establish after %d iterations" % iterations).throw();
    }

    // - verify all echo messages received -
    if (received.length() != test_messages.length())
    {
      new Exception("received: expected %d messages, got %d" %
        [test_messages.length(),received.length()]).throw();
    }

    idx = 0;
    while (idx < test_messages.length())
    {
      expected = "ECHO:%s" % test_messages[idx];
      if (received[idx] != expected)
      {
        new Exception("message %d: expected '%s', got '%s'" %
          [idx,expected,received[idx]]).throw();
      }
      idx += 1;
    }

    // - release reference cycles -
    free obj.m_poll_callbacks;
    free obj.m_ws_client;
    free obj.m_ctx;
  }/*}}}*/
}
